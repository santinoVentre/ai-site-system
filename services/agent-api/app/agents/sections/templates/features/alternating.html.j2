{# Alternating image/text rows #}
<section id="{{ section.id|default('features') }}" class="py-20 lg:py-24 bg-white">
  <div class="max-w-content mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal mb-14">
      {% if section.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ section.eyebrow }}</p>{% endif %}
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-bold tracking-tight">{{ section.headline }}</h2>
      {% if section.subheadline %}<p class="mt-4 text-lg text-slate-600">{{ section.subheadline }}</p>{% endif %}
    </div>

    <div class="space-y-16 lg:space-y-24">
      {% for f in section.items %}
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center reveal">
        <div class="{% if loop.index is even %}lg:order-last{% endif %}">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-slate-100 shadow-sm">
            {% if f.image_url %}
              <img src="{{ f.image_url }}" alt="{{ f.image_alt|default(f.title) }}" class="w-full h-full object-cover" loading="lazy" />
            {% else %}<div class="w-full h-full bg-gradient-to-br from-brand-100 to-brand-300"></div>{% endif %}
          </div>
        </div>
        <div>
          {% if f.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ f.eyebrow }}</p>{% endif %}
          <h3 class="mt-2 font-display text-2xl md:text-3xl font-bold text-ink">{{ f.title }}</h3>
          <p class="mt-4 text-slate-600 leading-relaxed text-lg">{{ f.description }}</p>
          {% if f.bullets %}
          <ul class="mt-5 space-y-2">
            {% for b in f.bullets %}<li class="flex gap-2 text-slate-700"><span class="text-brand-600 mt-1">&#10003;</span><span>{{ b }}</span></li>{% endfor %}
          </ul>
          {% endif %}
          {% if f.link_href %}<a href="{{ f.link_href }}" class="mt-6 inline-flex items-center text-sm font-semibold text-brand-700 hover:text-brand-800">{{ f.link_label|default('Scopri di più') }} <span aria-hidden="true" class="ml-1">&rarr;</span></a>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
