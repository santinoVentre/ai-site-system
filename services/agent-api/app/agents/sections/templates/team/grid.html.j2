{# Team grid with photo, name, role #}
<section id="{{ section.id|default('team') }}" class="py-20 lg:py-24 bg-white">
  <div class="max-w-content mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal">
      {% if section.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ section.eyebrow }}</p>{% endif %}
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-bold tracking-tight">{{ section.headline }}</h2>
      {% if section.subheadline %}<p class="mt-4 text-lg text-slate-600">{{ section.subheadline }}</p>{% endif %}
    </div>

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for m in section.items %}
      <article class="reveal text-center">
        <div class="aspect-square rounded-2xl overflow-hidden bg-slate-100">
          {% if m.avatar_url %}
            <img src="{{ m.avatar_url }}" alt="{{ m.name }}" class="w-full h-full object-cover" loading="lazy" />
          {% else %}
            <div class="w-full h-full bg-gradient-to-br from-brand-100 to-brand-300 flex items-center justify-center text-4xl font-bold text-brand-700">{{ m.name[:1]|upper }}</div>
          {% endif %}
        </div>
        <h3 class="mt-4 font-semibold text-ink">{{ m.name }}</h3>
        {% if m.role %}<p class="text-sm text-slate-500">{{ m.role }}</p>{% endif %}
        {% if m.bio %}<p class="mt-2 text-sm text-slate-600 line-clamp-3">{{ m.bio }}</p>{% endif %}
        {% if m.socials %}
        <div class="mt-3 flex justify-center gap-3">
          {% for s in m.socials %}<a href="{{ s.href }}" class="text-slate-500 hover:text-brand-700" aria-label="{{ s.label }}">{{ s.label }}</a>{% endfor %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>
