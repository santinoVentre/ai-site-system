{# Dynamic products — prerendered + hydrated #}
{% set cms_key = section.cms_key|default(section.id|default('products')) %}
{% set items = section.cms_items|default([]) %}
<section id="{{ section.id|default('products') }}" class="py-20 lg:py-24 bg-white"
         data-cms-section="{{ cms_key }}" data-cms-kind="products">
  <div class="max-w-content mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal mb-12">
      {% if section.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ section.eyebrow }}</p>{% endif %}
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-bold tracking-tight">{{ section.headline|default('Prodotti') }}</h2>
      {% if section.subheadline %}<p class="mt-4 text-lg text-slate-600">{{ section.subheadline }}</p>{% endif %}
    </div>
    <div class="reveal">
      <div data-cms-mount class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {% if items %}
          {% for it in items %}
            <article class="bg-surface rounded-2xl p-3 ring-1 ring-slate-200/70 flex flex-col">
              {% if it.image %}<img src="{{ it.image }}" alt="{{ it.name|default('') }}" loading="lazy" class="w-full aspect-square rounded-xl object-cover mb-3">{% endif %}
              {% if it.category %}<div class="text-xs text-slate-500">{{ it.category }}</div>{% endif %}
              <h3 class="font-medium text-ink text-sm">{{ it.name|default('') }}</h3>
              {% if it.description %}<p class="mt-1 text-xs text-slate-500 leading-relaxed">{{ it.description }}</p>{% endif %}
              <div class="mt-2 flex items-center justify-between">
                {% if it.price not in (None, '') %}<div class="font-semibold text-brand-700 text-sm">{{ it.price }}{% if it.price is number or (it.price|string).replace('.','',1).isdigit() %} €{% endif %}</div>{% else %}<span></span>{% endif %}
                {% if it.in_stock is sameas false %}<span class="text-xs text-rose-600">Esaurito</span>{% endif %}
              </div>
            </article>
          {% endfor %}
        {% else %}
          <p class="text-slate-500 text-sm text-center col-span-full">Caricamento prodotti…</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
