{# Generic dynamic section — prerendered + hydrated #}
{% set cms_key = section.cms_key|default(section.id|default('data')) %}
{% set items = section.cms_items|default([]) %}
{% set headers = [] %}
{% if items %}
  {% for k in items[0].keys() %}{% if k not in headers %}{% set _ = headers.append(k) %}{% endif %}{% endfor %}
{% endif %}
<section id="{{ section.id|default('data') }}" class="py-20 lg:py-24 bg-white"
         data-cms-section="{{ cms_key }}" data-cms-kind="generic">
  <div class="max-w-content mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal mb-10">
      {% if section.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ section.eyebrow }}</p>{% endif %}
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-bold tracking-tight">{{ section.headline|default('Dati') }}</h2>
      {% if section.subheadline %}<p class="mt-4 text-lg text-slate-600">{{ section.subheadline }}</p>{% endif %}
    </div>
    <div class="reveal bg-surface rounded-2xl p-6 ring-1 ring-slate-200/70 overflow-x-auto">
      <div data-cms-mount>
        {% if items %}
          <table class="w-full text-sm text-left">
            <thead><tr class="border-b border-slate-300">
              {% for h in headers %}<th class="py-2 pr-4 font-medium text-ink">{{ h }}</th>{% endfor %}
            </tr></thead>
            <tbody>
              {% for it in items %}
                <tr class="border-b border-slate-200">
                  {% for h in headers %}<td class="py-2 pr-4 text-slate-600">{{ it[h]|default('') }}</td>{% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p class="text-slate-500 text-sm">Caricamento…</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
