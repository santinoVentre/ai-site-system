{# Dynamic events — prerendered + hydrated #}
{% set cms_key = section.cms_key|default(section.id|default('events')) %}
{% set items = section.cms_items|default([]) %}
<section id="{{ section.id|default('events') }}" class="py-20 lg:py-24 bg-surface"
         data-cms-section="{{ cms_key }}" data-cms-kind="events">
  <div class="max-w-content mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto reveal mb-12">
      {% if section.eyebrow %}<p class="text-sm font-semibold uppercase tracking-wide text-brand-700">{{ section.eyebrow }}</p>{% endif %}
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-bold tracking-tight">{{ section.headline|default('Prossimi eventi') }}</h2>
      {% if section.subheadline %}<p class="mt-4 text-lg text-slate-600">{{ section.subheadline }}</p>{% endif %}
    </div>
    <div class="reveal">
      <div data-cms-mount class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% if items %}
          {% for it in items %}
            <article class="bg-white rounded-2xl overflow-hidden ring-1 ring-slate-200/70 flex flex-col">
              {% if it.image %}<img src="{{ it.image }}" alt="{{ it.title|default('') }}" loading="lazy" class="w-full h-44 object-cover">{% endif %}
              <div class="p-5 flex-1 flex flex-col">
                <div class="text-xs font-semibold uppercase tracking-wide text-brand-700">
                  {%- if it.date -%}{{ it.date }}{%- endif -%}
                  {%- if it.time %} · {{ it.time }}{% endif -%}
                </div>
                <h3 class="mt-1 font-semibold text-ink text-lg">{{ it.title|default('') }}</h3>
                {% if it.location %}<div class="text-sm text-slate-500 mt-1">📍 {{ it.location }}</div>{% endif %}
                {% if it.description %}<p class="mt-3 text-sm text-slate-600 leading-relaxed flex-1">{{ it.description }}</p>{% endif %}
                {% if it.link %}<a href="{{ it.link }}" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-700 hover:text-brand-800">Prenota →</a>{% endif %}
              </div>
            </article>
          {% endfor %}
        {% else %}
          <p class="text-slate-500 text-sm text-center col-span-full">Caricamento eventi…</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
