# ============================================================
# AI Site System - Environment Configuration
# Copy to .env and fill in real values before starting
# ============================================================

# ---- General ----
COMPOSE_PROJECT_NAME=ai-site-system
DOMAIN=sites.yourdomain.com
PROTOCOL=https

# ---- PostgreSQL ----
POSTGRES_PASSWORD=CHANGE_ME_pg_root_password
APP_DB_NAME=ai_site_system
APP_DB_USER=app_user
APP_DB_PASSWORD=CHANGE_ME_app_db_password
N8N_DB_NAME=n8n
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=CHANGE_ME_n8n_db_password

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---- n8n ----
N8N_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_admin_password
N8N_WEBHOOK_URL=https://sites.yourdomain.com/n8n/
GENERIC_TIMEZONE=Europe/Rome

# ---- Agent API ----
AGENT_API_SECRET=CHANGE_ME_agent_api_secret

# LLM via OpenRouter (recommended) — single key for all models
# Get your key at https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-CHANGE_ME
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Or use direct provider keys (leave OPENAI_BASE_URL empty):
# OPENAI_API_KEY=sk-CHANGE_ME
# OPENAI_BASE_URL=
ANTHROPIC_API_KEY=

# Default model — use OpenRouter model IDs (e.g. openai/gpt-4o, anthropic/claude-sonnet-4)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=openai/gpt-4o

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=CHANGE_ME_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_webhook_secret
TELEGRAM_ADMIN_CHAT_ID=CHANGE_ME_your_chat_id

# ---- Admin Dashboard ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ---- Paths ----
GENERATED_SITES_PATH=/data/generated-sites
ARTIFACTS_PATH=/data/artifacts
BACKUPS_PATH=/data/backups

# ---- Preview / Public URLs ----
PREVIEW_BASE_URL=https://sites.yourdomain.com/preview
SITE_BASE_URL=https://sites.yourdomain.com

# ---- CORS (comma-separated origins; leave empty for no CORS) ----
CORS_ALLOWED_ORIGINS=https://sites.yourdomain.com

# ---- Google Sheets ----
GOOGLE_SHEETS_CREDENTIALS_PATH=/secrets/gsheets-credentials.json
# Drive folder where new spreadsheets are created (service account must have access).
# Leave empty to let the service account create orphan files (requires Drive API + shared drive).
GOOGLE_DRIVE_FOLDER_ID=

# ---- Images (for agency-grade sites) ----
# Unsplash: free tier, 50 req/hour. https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
# Pexels: free tier, 200 req/hour. https://www.pexels.com/api/
PEXELS_API_KEY=
# Optional AI image generation via Replicate (FLUX). https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
AI_IMAGES_ENABLED=false

# ---- Quality loop ----
# Minimum reviewer score (0-100) to pass without iteration
QUALITY_SCORE_THRESHOLD=80
# Max builder re-runs driven by reviewer feedback
QUALITY_MAX_ITERATIONS=2

# ---- QA Runner ----
QA_RUNNER_URL=http://qa-runner:8001
QA_ENABLED=true

# ---- Observability ----
# Log level across all services (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Emit structured JSON log lines (recommended in production)
LOG_JSON=true
# Rate limiting (slowapi syntax: "<n>/<period>")
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_PUBLIC=60/minute
